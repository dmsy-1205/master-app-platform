{
  "rules": {
    ".read": false,
    ".write": false,
    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "users": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".indexOn": [
        "email"
      ],
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
      }
    },
    "apps": {
      ".read": "auth != null",
      "$appId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "applications": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
      }
    },
    "appAccessRequests": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$appId": {
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
          ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
        }
      }
    },
    "userAppAccess": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        "$appId": {
          ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
          ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
        }
      }
    },
    "applicationHistory": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$id": {
        ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "appRunLogs": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "executionLogs": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$appId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".write": "auth != null"
      }
    },
    "launchTokens": {
      "$token": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "feedbackBoard": {
      ".read": "auth != null",
      "$id": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "userFavorites": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
      }
    },
    "deleteRequests": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$requestId": {
        ".read": "auth != null && (data.child('requestUser').val() === auth.uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (newData.child('requestUser').val() === auth.uid || root.child('admins').child(auth.uid).val() === true)"
      }
    },
    "operationLogs": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$logId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    }
  }
}